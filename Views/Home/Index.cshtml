@using ViewsExample.Models
@{
        string title = "Views test";
        Person person = new Person() {Name = "John Doe", 
        DateofBirth = new DateTime(1990, 1, 1)};
 }
<!DOCTYPE html>
<html>
    <head> 
        <title>@title</title>
        <meta charset="utf-8" /> 
    </head>
    <body>
        <h1>Welcome to ASP.NET Core!</h1>
        <p>Name: @person.Name</p>
        <p>Date of Birth: @person.DateofBirth.ToString("yyyy-MM-dd")</p>
    </body>
</html>